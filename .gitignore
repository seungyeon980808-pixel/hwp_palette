# API 키/설정 (절대 커밋 금지)
config.json
*.env
.env

# 개인 라이브러리(서식/문자/템플릿) — 사용자별 데이터
library.json
fragments/

# 자동 백업 (backup.py 가 만든다)
# config.json 은 막아뒀는데 config.json.bak1 은 안 막혀 있어서, 백업 기능을
# 넣은 뒤로 개인 설정이 그대로 커밋되고 있었다. 확장자를 통째로 막는다.
*.bak
*.bak[0-9]

# exe 빌드 부산물
*.spec.bak

# Python
__pycache__/
*.pyc
.venv/
venv/

# 빌드 산출물
dist/
build/
*.exe

# 임시 한글 파일
~$*.hwp
~$*.hwpx

# 진단 로그
window_diag.log

# 앱 로그
app.log
